<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <div class="container py-4" style="max-width: 720px;">
      <h1 class="mb-4"><%= title %></h1>
      <div class="card mb-3">
        <div class="card-body" style="min-height: 120px;">
          <form action="/chat" method="POST" class="d-flex gap-2 mb-3">
            <input
              type="text"
              name="message"
              class="form-control"
              placeholder="メッセージを入力..."
              autocomplete="off"
              required
            />
            <button type="submit" class="btn btn-primary">送信</button>
          </form>
          <% if (userMessage) { %>
            <div class="mb-2">
              <span class="fw-bold text-primary">You:</span>
              <span class="ms-2"><%= userMessage %></span>
            </div>
          <% } %>
          <% if (aiMessage) { %>
            <div class="mb-2">
              <span class="fw-bold text-success">AI:</span>
              <span class="ms-2" style="white-space: pre-wrap;"><%= aiMessage %></span>
            </div>
          <% } %>
        </div>
      </div>
      <p class="text-muted small">Powered by Azure OpenAI on Azure App Service</p>
    </div>
  </body>
</html>
