# 00_provision.py の設定テンプレート。
# このファイルを .env にコピーし、必要な値だけコメントを外して設定する。
# .env は .gitignore 済み (個人の値)。env と .env では「シェルで明示した環境変数」が優先。

# サブスクリプション。未設定なら az の既定サブスクリプションを使う。
# AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# リソースグループ (既定: rg-foundry-agent)
# RG=rg-foundry-agent

# ★ Foundry アカウント名 = カスタムサブドメイン。グローバルに一意にすること (既定: foundry-agent-demo)
# ACCOUNT=foundry-agent-yourname

# プロジェクト名 (既定: agent-project)
# PROJECT=agent-project

# リージョン。モデルが使える場所にする (既定: eastus2)
# LOCATION=eastus2

# デプロイするモデル名 (既定: gpt-4.1-mini)。デプロイ名にもなり、エージェントの model に渡る
# MODEL=gpt-4.1-mini

# モデルバージョン。空なら Azure の既定版。list-models で確認した値を入れる
# MODEL_VERSION=

# エージェント名 (既定: MyAgent)
# AGENT=MyAgent
