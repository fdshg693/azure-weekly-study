# エフェメラルエージェントが接続する Foundry プロジェクトの設定テンプレート。
# このファイルを .env にコピーし、値を入れる（.env は .gitignore 済み）。
# 優先順位は「シェルの環境変数 > .env > 既定値」。
#
# このプロジェクトはリソースを作らない（手順は prompt_agent と同じなので省略）。
# prompt_agent を先に動かしたなら、生成された config.json の
#   project_endpoint → FOUNDRY_PROJECT_ENDPOINT
#   model_name       → FOUNDRY_MODEL
# をそのまま流用できる。

# プロジェクトエンドポイント（Foundry ポータルの welcome 画面に出る URL）。必須。
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# デプロイ済みモデルのデプロイ名（既定: gpt-4.1-mini）
FOUNDRY_MODEL=gpt-4.1-mini
