set shell := ["powershell.exe", "-c"]

# Variables
RESOURCE_GROUP := "rg-network-learn-observe"
LOCATION := "japaneast"
NSG := "nsg-app"

# List available commands
default:
    @just --list

# Create resource group and deploy resources (Network Watcher Agent の導入に数分かかります)
deploy:
    az group create --name {{RESOURCE_GROUP}} --location {{LOCATION}}
    az deployment group create --resource-group {{RESOURCE_GROUP}} --template-file main.bicep

# Show the NSG name, the two VM private IPs, and the flow-log storage account
info:
    $AIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmAPrivateIp.value -o tsv
    $BIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmBPrivateIp.value -o tsv
    $ST = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.storageAccountName.value -o tsv
    Write-Host "NSG under observation : {{NSG}}"
    Write-Host "vm-a private IP (観測する側 / 送信元): $AIP"
    Write-Host "vm-b private IP (観測される側 / 宛先): $BIP"
    Write-Host "Flow log storage account            : $ST"

# CORE 1a: IP Flow Verify — VNet 内からの SSH(22) は「許可」され、どのルールが効いたかを返す。
# 実トラフィックを流さずに「この通信は通る？ なぜ？」を NSG の評価結果として観測する。
# 期待: access=Allow / ruleName=Allow-SSH-From-Vnet
verify-allow:
    $AIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmAPrivateIp.value -o tsv
    $BIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmBPrivateIp.value -o tsv
    Write-Host "IP Flow Verify: Inbound TCP 22 to vm-b ($BIP) from a VNet source vm-a ($AIP)"
    Write-Host "EXPECT: Access=Allow, Rule=Allow-SSH-From-Vnet"
    az network watcher test-ip-flow --resource-group {{RESOURCE_GROUP}} --vm vm-b --nic nic-b --direction Inbound --protocol TCP --local "${BIP}:22" --remote "${AIP}:50000" -o json

# CORE 1b: IP Flow Verify — Internet からの SSH(22) は「拒否」され、効いているのが既定の
# DenyAllInBound であることを返す。Step1/4 の「直接 SSH は失敗」を、理由つきで説明できる形に。
# 期待: access=Deny / ruleName=DefaultRule_DenyAllInBound（許可は明示ルール・拒否は既定）
verify-deny:
    $BIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmBPrivateIp.value -o tsv
    Write-Host "IP Flow Verify: Inbound TCP 22 to vm-b ($BIP) from an INTERNET source (8.8.8.8)"
    Write-Host "EXPECT: Access=Deny, Rule=DefaultRule_DenyAllInBound (明示の許可が無いので既定の拒否で落ちる)"
    az network watcher test-ip-flow --resource-group {{RESOURCE_GROUP}} --vm vm-b --nic nic-b --direction Inbound --protocol TCP --local "${BIP}:22" --remote "8.8.8.8:50000" -o json

# CORE 2: 接続トラブルシュート — vm-a から vm-b:22 へ実際に疎通を試し、到達可否と経路（ホップ）を返す。
# ping で「通った」を体感していたものを、経路と遅延つきで観測できる形にする。
# 期待: connectionStatus=Reachable
test-conn:
    Write-Host "Connectivity test: vm-a -> vm-b on TCP 22 (実際にパケットを出して到達可否と経路を測る)"
    Write-Host "EXPECT: connectionStatus=Reachable"
    az network watcher test-connectivity --resource-group {{RESOURCE_GROUP}} --source-resource vm-a --dest-resource vm-b --dest-port 22 -o json

# CORE 3: Next Hop — vm-a から各宛先へのパケットが「次にどこへ向かうか」を UDR 込みで返す。
# Step3 の UDR 検証（経路を成立させているのは何か）を、判定結果として観測する。
# 期待: VNet 内宛て(vm-b)=VnetLocal / Internet 宛て(8.8.8.8)=Internet
next-hop:
    $AIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmAPrivateIp.value -o tsv
    $BIP = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.vmBPrivateIp.value -o tsv
    Write-Host "Next Hop from vm-a ($AIP) to vm-b ($BIP) [EXPECT: VnetLocal]:"
    az network watcher show-next-hop --resource-group {{RESOURCE_GROUP}} --vm vm-a --nic nic-a --source-ip $AIP --dest-ip $BIP -o json
    Write-Host "Next Hop from vm-a ($AIP) to Internet (8.8.8.8) [EXPECT: Internet]:"
    az network watcher show-next-hop --resource-group {{RESOURCE_GROUP}} --vm vm-a --nic nic-a --source-ip $AIP --dest-ip 8.8.8.8 -o json

# Enable NSG flow logs to the storage account (許可/拒否トラフィックを記録し始める)
flow-log-on:
    $ST = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.storageAccountName.value -o tsv
    $STID = az storage account show --resource-group {{RESOURCE_GROUP}} --name $ST --query id -o tsv
    Write-Host "Enabling NSG flow logs on {{NSG}} -> storage $ST ..."
    az network watcher flow-log create --resource-group {{RESOURCE_GROUP}} --location {{LOCATION}} --name fl-nsg-app --nsg {{NSG}} --storage-account $STID --enabled true
    Write-Host "Done. これ以降の許可/拒否トラフィックが Storage に記録されます。"

# Show the current flow log configuration (有効状態・保存先・バージョン)
flow-log-status:
    az network watcher flow-log show --resource-group {{RESOURCE_GROUP}} --location {{LOCATION}} --name fl-nsg-app -o json

# Generate some traffic so the flow log has something to record (vm-a -> vm-b へ数回アクセス)
generate-traffic:
    Write-Host "Generating traffic vm-a -> vm-b (ssh port knock x several) so the flow log captures it..."
    az vm run-command invoke --resource-group {{RESOURCE_GROUP}} --name vm-a --command-id RunShellScript --scripts "BIP=$(getent hosts vm-b | awk '{print \$1}'); for i in 1 2 3 4 5; do (echo > /dev/tcp/10.0.1.0/22) 2>/dev/null; nc -zv -w2 vm-b 22 2>&1 || true; done; echo done" --query "value[0].message" -o tsv
    Write-Host "数分後にフローログの blob が Storage に現れます（flow-log-blobs で確認）。"

# List the flow log blobs written to storage (記録された通信ログの実体を一覧する)
flow-log-blobs:
    $ST = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.storageAccountName.value -o tsv
    $KEY = az storage account keys list --resource-group {{RESOURCE_GROUP}} --account-name $ST --query "[0].value" -o tsv
    Write-Host "Flow log blobs in 'insights-logs-networksecuritygroupflowevent' (反映まで数分かかります):"
    az storage blob list --account-name $ST --account-key $KEY --container-name insights-logs-networksecuritygroupflowevent --query "[].name" -o tsv

# TOGGLE: SSH の許可より高優先度(90)の Deny ルールを足し、NSG の判定を覆す。
# 通信を流さなくても、verify-allow が Allow から Deny に変わる＝観測ツールが因果を捉える。
lock:
    Write-Host "Adding 'Deny-SSH-From-Vnet' at priority 90 (Allow=100 より高優先度なので拒否が勝つ)..."
    az network nsg rule create --resource-group {{RESOURCE_GROUP}} --nsg-name {{NSG}} --name Deny-SSH-From-Vnet --priority 90 --access Deny --direction Inbound --protocol Tcp --source-address-prefixes VirtualNetwork --destination-port-ranges 22
    Write-Host "Now run 'just verify-allow': access が Deny / rule が Deny-SSH-From-Vnet に変わるはず。"

# TOGGLE 戻し: Deny ルールを削除し、再び SSH 許可の状態に戻す。
unlock:
    Write-Host "Removing 'Deny-SSH-From-Vnet' (元の許可状態へ戻す)..."
    az network nsg rule delete --resource-group {{RESOURCE_GROUP}} --nsg-name {{NSG}} --name Deny-SSH-From-Vnet
    Write-Host "Now run 'just verify-allow': access が再び Allow / rule が Allow-SSH-From-Vnet に戻るはず。"

# Disable the NSG flow logs
flow-log-off:
    az network watcher flow-log delete --resource-group {{RESOURCE_GROUP}} --location {{LOCATION}} --name fl-nsg-app
    Write-Host "Flow log を無効化しました。"

# Delete resource group and all resources
destroy:
    az group delete --name {{RESOURCE_GROUP}} --yes --no-wait
