set shell := ["powershell.exe", "-c"]

# Variables
RESOURCE_GROUP := "rg-network-learn-azbastion"
LOCATION := "japaneast"
VNET := "vnet-azbastion"
SUBNET := "subnet-private"
BASTION := "azbastion"
# Local SSH key pair used to authenticate the Bastion-relayed SSH (created by `just keygen`).
KEY := "azbastion_key"

# List available commands
default:
    @just --list

# Generate a local SSH key pair (only if it does not exist yet). Never commit the private key.
keygen:
    if (-not (Test-Path {{KEY}})) { ssh-keygen -t ed25519 -f {{KEY}} -N '""' -C "azure-azbastion-lab"; Write-Host "Generated {{KEY}} / {{KEY}}.pub" } else { Write-Host "{{KEY}} already exists - skip" }

# Create resource group and deploy resources. NOTE: no "myIp" is needed -- unlike Step4 there is
# NO inbound SSH rule pinned to your global IP. Access goes through the authenticated Azure Bastion session.
# Deploying Azure Bastion (Standard) takes ~5-10 minutes.
deploy: keygen
    $PUBKEY = (Get-Content {{KEY}}.pub -Raw).Trim()
    az group create --name {{RESOURCE_GROUP}} --location {{LOCATION}}
    az deployment group create --resource-group {{RESOURCE_GROUP}} --template-file main.bicep --parameters adminPublicKey="$PUBKEY"

# Show the private VM IPs (NO public IP) and confirm there is NO bastion VM -- only the managed Azure Bastion.
info:
    Write-Host "Note: vm-private has NO public IP. And there is NO bastion VM -- the jump host is the managed Azure Bastion below."
    az vm list-ip-addresses --resource-group {{RESOURCE_GROUP}} --output table
    Write-Host "--- Managed Azure Bastion (the jump host, as a PaaS resource) ---"
    az network bastion list --resource-group {{RESOURCE_GROUP}} --query "[].{name:name, sku:sku.name, tunneling:enableTunneling}" --output table

# CORE: open an INTERACTIVE shell on the private VM THROUGH Azure Bastion (managed jump host).
# Contrast with Step4's `ssh -J`: no bastion VM, no public IP on the target, no NSG rule for your IP.
# Type `exit` to leave.
connect:
    $VMID = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.privateVmId.value -o tsv
    Write-Host "Connecting to vm-private via Azure Bastion '{{BASTION}}' (auth: ssh key)..."
    az network bastion ssh --name {{BASTION}} --resource-group {{RESOURCE_GROUP}} --target-resource-id "$VMID" --auth-type ssh-key --username azureuser --ssh-key {{KEY}}

# Scripted proof: tunnel local port 50022 -> private VM:22 through Azure Bastion, run a command, tear down.
# Proves we reached the private VM (no public IP) entirely via the managed Bastion. Needs Standard SKU + tunneling.
test:
    $VMID = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.privateVmId.value -o tsv
    Write-Host "Opening a Bastion tunnel (127.0.0.1:50022 -> vm-private:22)..."
    $job = Start-Job -ScriptBlock { param($rg, $b, $id) az network bastion tunnel --name $b --resource-group $rg --target-resource-id $id --resource-port 22 --port 50022 } -ArgumentList "{{RESOURCE_GROUP}}", "{{BASTION}}", "$VMID"
    Start-Sleep -Seconds 10
    Write-Host "Reaching the private VM through the tunnel with: ssh -p 50022 ..."
    ssh -i {{KEY}} -o StrictHostKeyChecking=no -o UserKnownHostsFile=NUL -p 50022 azureuser@127.0.0.1 "echo '--- reached vm-private via Azure Bastion (managed) ---'; hostname; hostname -I"
    Write-Host "Tearing down the tunnel..."
    Stop-Job $job; Remove-Job $job

# Lock down: remove the NSG rule that allows SSH from AzureBastionSubnet (Bastion can no longer reach the VM).
lock-private:
    Write-Host "Deleting 'Allow-SSH-From-Bastion' from nsg-private..."
    az network nsg rule delete --resource-group {{RESOURCE_GROUP}} --nsg-name nsg-private --name Allow-SSH-From-Bastion
    Write-Host "Removed. Run 'just connect' again: it should now FAIL (Azure Bastion can no longer reach vm-private)."

# Restore SSH from AzureBastionSubnet to the private VM (Bastion works again).
unlock-private:
    Write-Host "Re-creating 'Allow-SSH-From-Bastion' on nsg-private (source = AzureBastionSubnet 10.0.0.0/26)..."
    az network nsg rule create --resource-group {{RESOURCE_GROUP}} --nsg-name nsg-private --name Allow-SSH-From-Bastion --priority 100 --direction Inbound --access Allow --protocol Tcp --source-address-prefixes 10.0.0.0/26 --destination-port-ranges 22
    Write-Host "Restored. Run 'just connect' again to succeed."

# Delete resource group and all resources. Azure Bastion is billed per hour -- don't leave it running.
destroy:
    az group delete --name {{RESOURCE_GROUP}} --yes --no-wait
