set shell := ["powershell.exe", "-c"]

# Variables
RESOURCE_GROUP := "rg-network-learn-bastion"
LOCATION := "japaneast"
# Local SSH key pair used to authenticate BOTH hops (created by `just keygen`).
KEY := "bastion_key"
# Common SSH options to avoid interactive host-key prompts in this lab.
SSHOPT := "-o StrictHostKeyChecking=no -o UserKnownHostsFile=NUL"

# List available commands
default:
    @just --list

# Generate a local SSH key pair (only if it does not exist yet). Never commit the private key.
keygen:
    if (-not (Test-Path {{KEY}})) { ssh-keygen -t ed25519 -f {{KEY}} -N '""' -C "azure-bastion-lab"; Write-Host "Generated {{KEY}} / {{KEY}}.pub" } else { Write-Host "{{KEY}} already exists - skip" }

# Create resource group and deploy resources (auto-generates the SSH key, pins the bastion NSG to YOUR global IP)
deploy: keygen
    $MYIP = (Invoke-RestMethod -Uri 'https://api.ipify.org')
    Write-Host "Your global IP (the only source allowed to SSH the bastion): $MYIP"
    $PUBKEY = (Get-Content {{KEY}}.pub -Raw).Trim()
    az group create --name {{RESOURCE_GROUP}} --location {{LOCATION}}
    az deployment group create --resource-group {{RESOURCE_GROUP}} --template-file main.bicep --parameters adminPublicKey="$PUBKEY" myIp="$MYIP"

# Show each VM's IPs. Confirm vm-private has NO public IP (it is unreachable directly from the internet)
info:
    Write-Host "Note: vm-private should have an empty PublicIPAddresses column = no internet-facing entry point."
    az vm list-ip-addresses --resource-group {{RESOURCE_GROUP}} --output table

# SSH interactively into the BASTION host (allowed only from your IP). Type `exit` to leave.
ssh-bastion:
    $B = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.bastionPublicIp.value -o tsv
    Write-Host "SSH into bastion ($B)..."
    ssh -i {{KEY}} {{SSHOPT}} azureuser@$B

# Multi-hop SSH: JUMP through the bastion to reach the private VM (no public IP) and run a command there
test-jump:
    $B = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.bastionPublicIp.value -o tsv
    $P = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.privatePrivateIp.value -o tsv
    Write-Host "Jumping via bastion ($B) into private VM ($P) with: ssh -J ..."
    ssh -i {{KEY}} {{SSHOPT}} -J azureuser@$B azureuser@$P "echo '--- reached the private VM via the bastion ---'; hostname; hostname -I"

# Open an INTERACTIVE shell on the private VM through the bastion (ProxyJump). Type `exit` to leave.
ssh-private:
    $B = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.bastionPublicIp.value -o tsv
    $P = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.privatePrivateIp.value -o tsv
    Write-Host "Opening a shell on private VM ($P) via bastion ($B)..."
    ssh -i {{KEY}} {{SSHOPT}} -J azureuser@$B azureuser@$P

# Try to SSH the private VM DIRECTLY by its private IP from your local machine (EXPECTED TO FAIL - no public IP, no route)
test-direct-fail:
    $P = az deployment group show --resource-group {{RESOURCE_GROUP}} --name main --query properties.outputs.privatePrivateIp.value -o tsv
    Write-Host "Trying to SSH the private VM ($P) DIRECTLY from your local machine..."
    Write-Host "This is EXPECTED TO FAIL/TIMEOUT: it is a private IP with no internet-facing entry point. Use 'just test-jump' instead."
    ssh -i {{KEY}} {{SSHOPT}} -o ConnectTimeout=8 azureuser@$P "hostname"

# Lock down the private VM: remove the NSG rule that allows SSH from the bastion subnet (the jump will now FAIL)
lock-private:
    Write-Host "Deleting 'Allow-SSH-From-Bastion' from nsg-private..."
    az network nsg rule delete --resource-group {{RESOURCE_GROUP}} --nsg-name nsg-private --name Allow-SSH-From-Bastion
    Write-Host "Removed. Run 'just test-jump' again to see the jump FAIL (the bastion can no longer reach the private VM)."

# Restore SSH from the bastion subnet to the private VM (the jump works again)
unlock-private:
    Write-Host "Re-creating 'Allow-SSH-From-Bastion' on nsg-private (source = bastion subnet 10.0.0.0/24)..."
    az network nsg rule create --resource-group {{RESOURCE_GROUP}} --nsg-name nsg-private --name Allow-SSH-From-Bastion --priority 100 --direction Inbound --access Allow --protocol Tcp --source-address-prefixes 10.0.0.0/24 --destination-port-ranges 22
    Write-Host "Restored. Run 'just test-jump' again to see the jump SUCCEED."

# If your global IP changed (e.g. different Wi-Fi), refresh the bastion's allowed source IP so you can SSH again
update-myip:
    $MYIP = (Invoke-RestMethod -Uri 'https://api.ipify.org')
    Write-Host "Updating nsg-bastion to allow SSH from $MYIP ..."
    az network nsg rule update --resource-group {{RESOURCE_GROUP}} --nsg-name nsg-bastion --name Allow-SSH-From-MyIp --source-address-prefixes "$MYIP/32"

# Delete resource group and all resources
destroy:
    az group delete --name {{RESOURCE_GROUP}} --yes --no-wait
