# このファイルをコピーして .env を作り、値を埋める（PowerShell: Copy-Item .env.example .env）。
# ★ CLIENT_SECRET は本物の秘密。.env は .gitignore 済みなのでコミットされない。

# Entra ID テナント ID。`task tenant` で取得できる。
TENANT_ID=00000000-0000-0000-0000-000000000000

# --- デーモン（クライアント）側 ---

# デーモン自身のアプリ登録の「アプリケーション (クライアント) ID」。`task register` の出力 CLIENT_ID。
CLIENT_ID=00000000-0000-0000-0000-000000000000

# ★ クライアントシークレット（資格情報）。`task register` で発行され、その一度だけ表示される。
#   confidential-web と同じ「アプリのパスワード」だが、こちらは **ユーザー不在** で client credentials に使う。
CLIENT_SECRET=PASTE-THE-SECRET-FROM-task-register

# --- 呼ぶ相手＝自前 API 側 ---

# 自前 API のアプリ登録の「アプリケーション (クライアント) ID」。`task register` の出力 API_CLIENT_ID。
# デーモンは scope を api://<API_CLIENT_ID>/.default にしてトークンを要求し、API は aud=api://<API_CLIENT_ID> を検証する。
API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- 以下は既定値があるので通常は変更不要 ---

# 自前 API（api/server.js）の待ち受けポート。
API_PORT=3000

# デーモン（daemon/daemon.js）が叩く API のベース URL。
API_BASE=http://localhost:3000
