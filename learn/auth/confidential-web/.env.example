# このファイルをコピーして .env を作り、値を埋める（PowerShell: Copy-Item .env.example .env）。
# ★ CLIENT_SECRET は本物の秘密。.env は .gitignore 済みなのでコミットされない。

# Entra ID テナント ID。`task tenant` で取得できる。
TENANT_ID=00000000-0000-0000-0000-000000000000

# コンフィデンシャルな Web アプリのアプリ登録の「アプリケーション (クライアント) ID」。`task register` の出力 CLIENT_ID。
CLIENT_ID=00000000-0000-0000-0000-000000000000

# ★ クライアントシークレット（資格情報）。`task register` で発行され、その一度だけ表示される。
#   パブリッククライアント（SPA）には存在しないもの。これがあるからコンフィデンシャル。
CLIENT_SECRET=PASTE-THE-SECRET-FROM-task-register

# --- 以下はサーバー（server/server.js）が使う。既定値があるので通常は変更不要 ---

# サーバーの待ち受けポート。
PORT=3000

# Entra に登録した Web プラットフォームのリダイレクト URI と「完全一致」させる。
REDIRECT_URI=http://localhost:3000/auth/callback

# ログアウト後の戻り先。
POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# 要求するスコープ（スペース区切り）。本人確認＋Graph 代理呼び出し＋リフレッシュトークン。
SCOPES=openid profile email offline_access User.Read
