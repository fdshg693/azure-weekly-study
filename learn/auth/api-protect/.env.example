# このファイルをコピーして .env を作り、値を埋める（PowerShell: Copy-Item .env.example .env）。
# いずれも秘密情報ではない（公開されても問題ない）が、設定の出どころを一箇所にまとめるため .env で管理する。

# Entra ID テナント ID。`just tenant` で取得できる。
TENANT_ID=00000000-0000-0000-0000-000000000000

# SPA（クライアント）側のアプリ登録の「アプリケーション (クライアント) ID」。`just register` の出力 SPA_CLIENT_ID。
SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# 自前 API（リソースサーバー）側のアプリ登録の「アプリケーション (クライアント) ID」。`just register` の出力 API_CLIENT_ID。
# SPA が要求するスコープ（api://<API_CLIENT_ID>/access_as_user）と、API が検証する aud の両方に使う。
API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ログイン後の戻り先。SPA アプリ登録のリダイレクト URI と「完全一致」させる。
REDIRECT_URI=http://localhost:5173

# SPA から呼ぶ自前 API のベース URL（SPA 側が使用）。
API_BASE_URL=http://localhost:3000

# --- 以下は自前 API サーバ（api/server.js）が使う。既定値があるので通常は変更不要 ---

# API の待ち受けポート（API_BASE_URL のポートと揃える）。
API_PORT=3000

# API が CORS で許可するオリジン（= SPA の配信元）。
SPA_ORIGIN=http://localhost:5173
