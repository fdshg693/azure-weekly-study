# このファイルをコピーして .env を作り、値を埋める（PowerShell: Copy-Item .env.example .env）。
# ★ API_A_CLIENT_SECRET は本物の秘密。.env は .gitignore 済みなのでコミットされない。

# Entra ID テナント ID。`task tenant` で取得できる。
TENANT_ID=00000000-0000-0000-0000-000000000000

# --- SPA（ユーザーがログインする側） ---

# SPA のアプリ登録の「アプリケーション (クライアント) ID」。`task register` の出力 SPA_CLIENT_ID。
SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- 中間 API(A)：SPA が呼ぶ相手かつ、B を OBO で呼ぶクライアント ---

# 中間 API(A) のアプリ登録の「アプリケーション (クライアント) ID」。`task register` の出力 API_A_CLIENT_ID。
# SPA は scope を api://<API_A_CLIENT_ID>/access_as_user にしてトークンを要求し、A は aud=api://<API_A_CLIENT_ID> を検証する。
API_A_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ★ 中間 API(A) のクライアントシークレット（資格情報）。`task register` で発行され、その一度だけ表示される。
#   用途は OBO 交換：受け取ったユーザートークンを B 宛トークンへ交換するときに A が token エンドポイントへ提示する。
API_A_CLIENT_SECRET=PASTE-THE-SECRET-FROM-task-register

# --- 下流 API(B)：A が OBO で呼ぶ相手 ---

# 下流 API(B) のアプリ登録の「アプリケーション (クライアント) ID」。`task register` の出力 API_B_CLIENT_ID。
# A は OBO の scope を api://<API_B_CLIENT_ID>/access_as_user にし、B は aud=api://<API_B_CLIENT_ID> を検証する。
API_B_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- SPA の config.js 生成に使う値（gen-config.ps1 が参照） ---

# SPA をローカル配信する URL（リダイレクト URI）。register.ps1 が登録する値と一致させること。
REDIRECT_URI=http://localhost:5173

# SPA が呼ぶ中間 API(A) のベース URL。
API_A_BASE_URL=http://localhost:3000

# --- 以下は既定値があるので通常は変更不要 ---

# 中間 API(A) の待ち受けポート。
API_A_PORT=3000

# 下流 API(B) の待ち受けポート。
API_B_PORT=3001

# 中間 API(A) が叩く下流 API(B) のベース URL。
API_B_BASE=http://localhost:3001

# CORS で許可する SPA のオリジン（中間 API が参照）。
SPA_ORIGIN=http://localhost:5173
