{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "<デプロイ済み Storage Account の接続文字列、または Azurite なら UseDevelopmentStorage=true>",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "AzureWebJobsFeatureFlags": "EnableWorkerIndexing",
    "UPLOADS_CONTAINER": "uploads",
    "LOGS_CONTAINER": "logs"
  }
}
