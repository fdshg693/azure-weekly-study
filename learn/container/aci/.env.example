# このプロジェクトに秘密値は無い。既定から変えたいときだけ .env にコピーして使う
# (.env は .gitignore 済み)。設定しなければ scripts 内の既定値が使われる。

# このプロジェクト (ACI) のデプロイ先リソースグループ
RG=rg-container-aci

# リージョン
LOCATION=japaneast

# リソース名プレフィックス (Container Group 名 cg-<PREFIX>-web / DNS ラベルに使う・英数字・短め)
PREFIX=aci

# Step 1 (registry) をデプロイした RG。ここから ACR / 消費者 UAMI を引いてくる。
REGISTRY_RG=rg-container-registry

# registry に上げたイメージ (repository / tag)。registry 側の既定と合わせる。
REPO=web
TAG=v1
