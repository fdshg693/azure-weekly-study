# このプロジェクトに秘密値は無い。RG / LOCATION / PREFIX を既定から変えたいときだけ
# このファイルを .env にコピーして使う（.env は .gitignore 済み）。
# 設定しなければ scripts 内の既定値（rg-container-registry / japaneast / reg）が使われる。

# デプロイ先リソースグループ名
RG=rg-container-registry

# リージョン
LOCATION=japaneast

# リソース名プレフィックス（ACR 名 acr<PREFIX><一意サフィックス> に使う。英数字・短め）
PREFIX=reg

# レジストリ内のイメージ名（リポジトリ名）。レジストリ内で一意なら何でもよい。
# 例: web / myapp / team-a/web（ネスト namespace も可）
REPO=web
