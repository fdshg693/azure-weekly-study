# db/simple の接続設定。`just init-env` で .env を生成すると PGPASSWORD が
# ランダム生成され、`just deploy` 後に PGHOST が自動で書き込まれる。
# 手動で使う場合はこのファイルを .env にコピーして値を埋める。

# 接続先ホスト (FQDN)。deploy 後に justfile が自動で書き込む。
PGHOST=

# 接続ユーザー (= Bicep の adminUsername)
PGUSER=pgadmin

# 管理者パスワード。init-env がランダム生成して入れる。
PGPASSWORD=

# 接続する論理データベース名 (= Bicep の databaseName)
PGDATABASE=appdb

# マネージド PostgreSQL はデフォルトで TLS 必須。require のままにする。
PGSSLMODE=require
