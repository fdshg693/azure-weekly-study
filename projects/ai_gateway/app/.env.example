# ============================================================================
# AI Gateway アプリ（ステップ1: データプレーン推論）— 環境変数サンプル
# ============================================================================
# このファイルを app/.env にコピーして値を埋める（.env は .gitignore 済み）。
#   cp .env.example .env
# - 既にシェルで export 済みの環境変数が優先され、.env では上書きされない。
# - 認証はキーレス（Managed Identity / az login）。API キーは置かない。

# Azure OpenAI のエンドポイント（データプレーン推論の宛先）。
# プロジェクト直下で `just app-env-sync` を実行すると terraform output から取得できる。
# 例: https://aoai-aigw-dev-seiwan.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI アカウントの「フルリソース ID」（コントロールプレーン /deployments, /models の宛先）。
# ステップ2 で追加。データプレーンの endpoint とは別物（ARM 側の宛先）。
# `just app-env-sync` で terraform output(openai_account_id)から取得できる。
# 例: /subscriptions/xxxx/resourceGroups/rg-aigw-dev-seiwan/providers/Microsoft.CognitiveServices/accounts/aoai-aigw-dev-seiwan
AZURE_OPENAI_ACCOUNT_ID=

# 既定のデプロイ名（手動で 1 つだけ作ったモデルのデプロイ名）。
# 重要: これは「モデル名」ではなく「デプロイ名」。Azure OpenAI は推論時に必ずデプロイ名で呼ぶ。
# Responses API 対応モデル（GPT-4.1 / GPT-5 等）でデプロイすること。
# リクエストの body で deployment を渡せば、その都度上書きできる。
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# 推論用 API バージョン（任意。未設定なら 2025-04-01-preview）。
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# コントロールプレーン（ARM）用 API バージョン（任意。未設定なら 2025-06-01）。
# 推論用とは別系統のバージョン体系である点に注意（PLAN §2）。
# AZURE_OPENAI_ARM_API_VERSION=2025-06-01

# サーバーポート（任意・既定 3000）
# PORT=3000
