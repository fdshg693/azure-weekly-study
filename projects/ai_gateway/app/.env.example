# ============================================================================
# AI Gateway アプリ（ステップ1: データプレーン推論）— 環境変数サンプル
# ============================================================================
# このファイルを app/.env にコピーして値を埋める（.env は .gitignore 済み）。
#   cp .env.example .env
# - 既にシェルで export 済みの環境変数が優先され、.env では上書きされない。
# - 認証はキーレス（Managed Identity / az login）。API キーは置かない。

# Azure OpenAI のエンドポイント。
# プロジェクト直下で `just env-sync` を実行すると terraform output から取得できる。
# 例: https://aoai-aigw-dev-seiwan.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# 既定のデプロイ名（手動で 1 つだけ作ったモデルのデプロイ名）。
# 重要: これは「モデル名」ではなく「デプロイ名」。Azure OpenAI は推論時に必ずデプロイ名で呼ぶ。
# Responses API 対応モデル（GPT-4.1 / GPT-5 等）でデプロイすること。
# リクエストの body で deployment を渡せば、その都度上書きできる。
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# 推論用 API バージョン（任意。未設定なら 2025-04-01-preview）。
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# サーバーポート（任意・既定 3000）
# PORT=3000
