<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <div class="container py-4" style="max-width: 960px;">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h1 class="mb-0 h3"><%= title %></h1>
        <span class="badge text-bg-secondary">PLAN §4 ステップ4</span>
      </div>
      <p class="text-muted small mb-4">
        コントロールプレーン（デプロイの一覧/作成/削除）とデータプレーン（推論）を 1 画面で。
        「作ったモデルをその場で呼んで結果が返る」を体験する。
      </p>

      <!-- 画面上部に共通の通知バナー（成功/失敗をここに出す） -->
      <div id="notice" class="alert d-none" role="alert"></div>

      <!-- ================= デプロイ一覧（コントロールプレーン読み取り） ================= -->
      <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="fw-bold">デプロイ一覧</span>
          <div class="d-flex align-items-center gap-2">
            <span id="poll-indicator" class="small text-muted d-none">状態を更新中…</span>
            <button id="refresh-btn" class="btn btn-outline-secondary btn-sm">再読み込み</button>
          </div>
        </div>
        <div class="card-body p-0">
          <table class="table table-sm mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>デプロイ名</th>
                <th>モデル</th>
                <th>バージョン</th>
                <th>状態</th>
                <th>SKU</th>
                <th class="text-end">容量(TPM)</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="deployments-body">
              <tr><td colspan="7" class="text-center text-muted py-3">読み込み中…</td></tr>
            </tbody>
          </table>
        </div>
        <div class="card-footer small text-muted">
          「デプロイ名」と「モデル名」は別物。推論時は必ず<strong>デプロイ名</strong>で呼ぶ。
          作成直後は状態が <code>Accepted</code>/<code>Creating</code> で、<code>Succeeded</code>
          になるまで自動でポーリングします。
        </div>
      </div>

      <!-- ================= 新規デプロイ作成（コントロールプレーン書き込み） ================= -->
      <div class="card mb-4">
        <div class="card-header fw-bold">新規デプロイ作成</div>
        <div class="card-body">
          <form id="create-form" class="row g-3">
            <div class="col-md-6">
              <label class="form-label small">ベースモデル</label>
              <!-- /models（このリージョンの可用モデル）から生成。選ぶと version/sku 候補が連動する。 -->
              <select id="model-select" class="form-select form-select-sm" required>
                <option value="">読み込み中…</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label small">バージョン</label>
              <select id="version-select" class="form-select form-select-sm" required>
                <option value="">モデルを選択</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small">SKU</label>
              <select id="sku-select" class="form-select form-select-sm" required>
                <option value="">モデルを選択</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small">容量 (TPM)</label>
              <input id="capacity-input" type="number" min="1" value="10" class="form-control form-control-sm" required />
            </div>
            <div class="col-md-4">
              <label class="form-label small">デプロイ名</label>
              <!-- 既定でモデル名を入れる。任意の名前に変えられる（モデル名と別でよい）。 -->
              <input id="deployment-input" type="text" class="form-control form-control-sm" placeholder="例: gpt-4.1" required />
            </div>
            <div class="col-12">
              <button id="create-btn" type="submit" class="btn btn-primary btn-sm">デプロイを作成</button>
              <span class="small text-muted ms-2">
                容量がクォータ上限を超えると ARM が 4xx を返します（ステップ5 の体験）。
              </span>
            </div>
          </form>
        </div>
      </div>

      <!-- ================= チャット試し打ち（データプレーン推論） ================= -->
      <div class="card mb-4">
        <div class="card-header fw-bold">チャット試し打ち（推論）</div>
        <div class="card-body">
          <form id="infer-form" class="row g-3">
            <div class="col-md-4">
              <label class="form-label small">デプロイ名</label>
              <!-- 一覧の Succeeded なデプロイから生成。ここで選んだ名前で /infer を叩く。 -->
              <select id="infer-deployment" class="form-select form-select-sm" required>
                <option value="">デプロイを選択</option>
              </select>
            </div>
            <div class="col-md-8">
              <label class="form-label small">プロンプト</label>
              <div class="d-flex gap-2">
                <input id="infer-prompt" type="text" class="form-control form-control-sm" placeholder="日本の首都は？" required />
                <button id="infer-btn" type="submit" class="btn btn-success btn-sm text-nowrap">送信</button>
              </div>
            </div>
          </form>
          <div id="infer-result" class="mt-3 d-none">
            <label class="form-label small text-muted mb-1">応答</label>
            <div id="infer-reply" class="border rounded p-2 bg-white" style="white-space: pre-wrap; min-height: 2.5rem;"></div>
          </div>
        </div>
        <div class="card-footer small text-muted">
          状態が <code>Succeeded</code> のデプロイだけ選べます。作成直後で未完了の場合は一覧の更新を待ってください。
        </div>
      </div>

      <p class="text-muted small">AI Gateway — 自作の薄い Express プロキシ（Managed Identity / キーレス）</p>
    </div>

    <script>
      (() => {
        // サーバーから渡された既定デプロイ名（チャットの初期選択に使う）。
        const DEFAULT_DEPLOYMENT = <%- JSON.stringify(defaultDeployment) %>;

        const $ = (id) => document.getElementById(id);
        const notice = $("notice");
        let pollTimer = null;

        // 共通の通知バナー（success / danger）。
        function showNotice(message, kind = "success") {
          notice.className = "alert alert-" + kind;
          notice.textContent = message;
          notice.classList.remove("d-none");
        }
        function clearNotice() {
          notice.classList.add("d-none");
        }

        // fetch して JSON を返す。!ok なら error/status を含めて throw（API の status をそのまま見せる）。
        async function api(path, options) {
          const res = await fetch(path, options);
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            const err = new Error(data.error || res.statusText);
            err.status = data.status || res.status;
            throw err;
          }
          return data;
        }

        // ---- デプロイ一覧 -------------------------------------------------------
        const SUCCEEDED = "Succeeded";

        function renderDeployments(deployments) {
          const body = $("deployments-body");
          body.innerHTML = "";
          if (!deployments.length) {
            body.innerHTML =
              '<tr><td colspan="7" class="text-center text-muted py-3">デプロイはまだありません。下のフォームから作成してください。</td></tr>';
          }
          for (const d of deployments) {
            const tr = document.createElement("tr");
            // 状態に応じて色分け（Succeeded=緑 / それ以外=進行中の黄）。
            const done = d.state === SUCCEEDED;
            const badge = done ? "text-bg-success" : "text-bg-warning";
            tr.innerHTML =
              `<td class="fw-semibold">${esc(d.deployment)}</td>` +
              `<td>${esc(d.model)}</td>` +
              `<td>${esc(d.version)}</td>` +
              `<td><span class="badge ${badge}">${esc(d.state)}</span></td>` +
              `<td>${esc(d.sku)}</td>` +
              `<td class="text-end">${esc(d.capacity)}</td>` +
              `<td class="text-end"></td>`;
            const delBtn = document.createElement("button");
            delBtn.className = "btn btn-outline-danger btn-sm";
            delBtn.textContent = "削除";
            delBtn.addEventListener("click", () => deleteDeployment(d.deployment));
            tr.lastElementChild.appendChild(delBtn);
            body.appendChild(tr);
          }
          // チャット用のデプロイ選択肢（Succeeded のものだけ）を同期。
          syncInferDeployments(deployments.filter((d) => d.state === SUCCEEDED));
          // 進行中（未 Succeeded）があれば自動ポーリングを継続。
          const pending = deployments.some((d) => d.state !== SUCCEEDED);
          $("poll-indicator").classList.toggle("d-none", !pending);
          if (pending) schedulePoll();
          else if (pollTimer) {
            clearTimeout(pollTimer);
            pollTimer = null;
          }
        }

        async function loadDeployments() {
          try {
            const { deployments } = await api("/deployments");
            renderDeployments(deployments);
          } catch (err) {
            showNotice(`デプロイ一覧の取得に失敗しました（${err.status || "?"}）: ${err.message}`, "danger");
            $("deployments-body").innerHTML =
              '<tr><td colspan="7" class="text-center text-danger py-3">取得に失敗しました</td></tr>';
          }
        }

        // 進行中デプロイがある間だけ 5 秒ごとに再取得（多重起動を防ぐため timer を 1 本に保つ）。
        function schedulePoll() {
          if (pollTimer) return;
          pollTimer = setTimeout(async () => {
            pollTimer = null;
            await loadDeployments();
          }, 5000);
        }

        async function deleteDeployment(name) {
          if (!confirm(`デプロイ「${name}」を削除しますか？`)) return;
          clearNotice();
          try {
            await api("/deployments/" + encodeURIComponent(name), { method: "DELETE" });
            showNotice(`削除を受け付けました: ${name}（反映まで一覧を更新します）`);
            await loadDeployments();
          } catch (err) {
            showNotice(`削除に失敗しました（${err.status || "?"}）: ${err.message}`, "danger");
          }
        }

        // ---- 新規デプロイ作成 ---------------------------------------------------
        let modelsCache = []; // /models の結果（version/sku 連動に使う）

        async function loadModels() {
          const modelSelect = $("model-select");
          try {
            const { models } = await api("/models");
            modelsCache = models;
            // モデル名はリージョンに複数バージョンがあるため、モデル名でユニーク化して選択肢にする。
            const names = [...new Set(models.map((m) => m.model))].sort();
            modelSelect.innerHTML =
              '<option value="">選択してください</option>' +
              names.map((n) => `<option value="${esc(n)}">${esc(n)}</option>`).join("");
          } catch (err) {
            modelSelect.innerHTML = '<option value="">取得失敗</option>';
            showNotice(`モデル一覧の取得に失敗しました（${err.status || "?"}）: ${err.message}`, "danger");
          }
        }

        // モデルを選んだら、そのモデルの version / sku 候補を絞り込んで表示。
        function onModelChange() {
          const model = $("model-select").value;
          const versionSelect = $("version-select");
          const skuSelect = $("sku-select");
          const deploymentInput = $("deployment-input");
          const entries = modelsCache.filter((m) => m.model === model);

          const versions = [...new Set(entries.map((m) => m.version))].sort().reverse();
          versionSelect.innerHTML = versions.length
            ? versions.map((v) => `<option value="${esc(v)}">${esc(v)}</option>`).join("")
            : '<option value="">-</option>';

          // SKU は全バージョン分をまとめて候補に（GlobalStandard を既定で先頭に）。
          const skus = [...new Set(entries.flatMap((m) => m.skus || []))];
          skus.sort((a, b) => (a === "GlobalStandard" ? -1 : b === "GlobalStandard" ? 1 : 0));
          skuSelect.innerHTML = skus.length
            ? skus.map((s) => `<option value="${esc(s)}">${esc(s)}</option>`).join("")
            : '<option value="">-</option>';

          // デプロイ名が未入力なら、利便のためモデル名を初期値に入れる。
          if (model && !deploymentInput.value) deploymentInput.value = model;
        }

        async function onCreateSubmit(e) {
          e.preventDefault();
          clearNotice();
          const btn = $("create-btn");
          const payload = {
            deployment: $("deployment-input").value.trim(),
            model: $("model-select").value,
            version: $("version-select").value,
            sku: $("sku-select").value,
            capacity: Number($("capacity-input").value),
          };
          if (!payload.deployment || !payload.model || !payload.version) {
            showNotice("デプロイ名・モデル・バージョンは必須です", "danger");
            return;
          }
          btn.disabled = true;
          try {
            const { deployment } = await api("/deployments", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            showNotice(`作成を受け付けました: ${deployment.deployment}（状態: ${deployment.state}）`);
            await loadDeployments(); // 進行中なら自動ポーリングが始まる
          } catch (err) {
            showNotice(`作成に失敗しました（${err.status || "?"}）: ${err.message}`, "danger");
          } finally {
            btn.disabled = false;
          }
        }

        // ---- チャット試し打ち ---------------------------------------------------
        function syncInferDeployments(succeeded) {
          const sel = $("infer-deployment");
          const prev = sel.value;
          sel.innerHTML =
            '<option value="">デプロイを選択</option>' +
            succeeded.map((d) => `<option value="${esc(d.deployment)}">${esc(d.deployment)}</option>`).join("");
          // 直前の選択 → 既定デプロイ → 先頭、の優先順で復元する。
          const names = succeeded.map((d) => d.deployment);
          if (prev && names.includes(prev)) sel.value = prev;
          else if (DEFAULT_DEPLOYMENT && names.includes(DEFAULT_DEPLOYMENT)) sel.value = DEFAULT_DEPLOYMENT;
        }

        async function onInferSubmit(e) {
          e.preventDefault();
          clearNotice();
          const deployment = $("infer-deployment").value;
          const prompt = $("infer-prompt").value.trim();
          if (!deployment || !prompt) {
            showNotice("デプロイと プロンプトを入力してください", "danger");
            return;
          }
          const btn = $("infer-btn");
          const result = $("infer-result");
          const reply = $("infer-reply");
          btn.disabled = true;
          result.classList.remove("d-none");
          reply.textContent = "…";
          try {
            const data = await api("/infer", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ deployment, prompt }),
            });
            reply.textContent = data.reply || "(空の応答)";
          } catch (err) {
            reply.textContent = `エラー（${err.status || "?"}）: ${err.message}`;
          } finally {
            btn.disabled = false;
          }
        }

        // HTML エスケープ（テーブル/選択肢にユーザー由来の文字列を埋め込むため最低限）。
        function esc(v) {
          return String(v ?? "").replace(/[&<>"']/g, (c) =>
            ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c])
          );
        }

        // ---- 配線 --------------------------------------------------------------
        $("refresh-btn").addEventListener("click", loadDeployments);
        $("model-select").addEventListener("change", onModelChange);
        $("create-form").addEventListener("submit", onCreateSubmit);
        $("infer-form").addEventListener("submit", onInferSubmit);

        // 初回ロード: 一覧とモデル候補を並行取得。
        loadDeployments();
        loadModels();
      })();
    </script>
  </body>
</html>
