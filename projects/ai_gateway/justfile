set shell := ["pwsh.exe", "-NoLogo", "-NoProfile", "-Command"]

# Terraform variables.tf のデフォルト値と合わせる
resource_group := "rg-aigw-dev-seiwan"
openai_account := "aoai-aigw-dev-seiwan"

default:
  @just --list

# ----------------------------------------------------------------------------
# Terraform（ステップ0: IaC 土台）
# ----------------------------------------------------------------------------

# プロバイダーを初期化
init:
  @terraform init

# 変更内容のプレビュー
plan:
  @terraform plan

# インフラを作成・更新（確認なし）。※実リソースを作るのでガードレールに注意（README参照）
apply:
  @terraform apply -auto-approve

# インフラを削除（確認なし）。学習後の後片付け用
destroy:
  @terraform destroy -auto-approve

# 出力値を表示
output:
  @terraform output

# ----------------------------------------------------------------------------
# 動作確認 / 体験
# ----------------------------------------------------------------------------

# ステップ0 の土台ができたか確認（アカウント / デプロイ0件 / ロール）
verify:
  @pwsh -NoProfile -File scripts/verify.ps1 -ResourceGroup "{{resource_group}}" -OpenAiAccount "{{openai_account}}"

# このリージョンでデプロイ可能なベースモデル一覧（後続ステップの選択肢になる）
models:
  @az cognitiveservices account list-models -n {{openai_account}} -g {{resource_group}} --query "[].{model:name, version:version, format:format, sku:skus[0].name}" --output table

# ----------------------------------------------------------------------------
# モデルデプロイ操作（コントロールプレーン書き込み・要 Contributor ロール）
# ※ 本来はステップ3 で管理 UI から行う対象。それまでの動作確認用 CLI ラッパー。
# ----------------------------------------------------------------------------

# モデルをデプロイ（ステップ1 の前提づくり）。引数省略時は GPT-4.1 / GlobalStandard / TPM 10。
# 例: just deploy-model  /  just deploy-model gpt-5 gpt-5 2025-08-07  /  just deploy-model gpt-4.1 gpt-4.1 2025-04-14 GlobalStandard 1
deploy-model name="gpt-4.1" model="gpt-4.1" version="2025-04-14" sku="GlobalStandard" capacity="10":
  @pwsh -NoProfile -File scripts/deploy-model.ps1 -ResourceGroup "{{resource_group}}" -OpenAiAccount "{{openai_account}}" -DeploymentName "{{name}}" -ModelName "{{model}}" -ModelVersion "{{version}}" -Sku "{{sku}}" -Capacity {{capacity}}

# 作成済みデプロイの一覧（デプロイ名・モデル・状態・容量を確認）
deploy-list:
  @az cognitiveservices account deployment list -n {{openai_account}} -g {{resource_group}} --query "[].{deployment:name, model:properties.model.name, version:properties.model.version, state:properties.provisioningState, sku:sku.name, capacity:sku.capacity}" --output table

# デプロイを削除（後片付け / ステップ5 の体験用）。例: just deploy-delete gpt-4.1
deploy-delete name:
  @az cognitiveservices account deployment delete -n {{openai_account}} -g {{resource_group}} --deployment-name "{{name}}" && echo "deleted deployment: {{name}}"

# terraform output からエンドポイントを .env に書き出す（後続ステップのアプリ用）
env-sync:
  @$endpoint = (terraform output -raw openai_endpoint); Set-Content -Path .env -Value "AZURE_OPENAI_ENDPOINT=$endpoint"; Write-Host "Wrote .env (AZURE_OPENAI_ENDPOINT=$endpoint)"

# 自分のロール割り当て状況だけを確認（読み取り専用）
roles:
  @$id = (terraform output -raw openai_account_id); az role assignment list --scope $id --output table

# ----------------------------------------------------------------------------
# アプリ（ステップ1: データプレーン推論の最小エンドポイント）
# ----------------------------------------------------------------------------

# 依存パッケージをインストール
app-install:
  @npm --prefix app install

# terraform output から app/.env を用意（endpoint + account-id + 既定 deployment）
app-env-sync:
  @pwsh -NoProfile -File scripts/app-env-sync.ps1

# アプリを起動（要 az login。app/.env の AZURE_OPENAI_ENDPOINT / AZURE_OPENAI_DEPLOYMENT を使う）
# ステップ4 以降は管理 UI も同時に公開される（http://localhost:3000/）。
app-dev:
  @node app/server.js

# 管理 UI（ステップ4）を既定ブラウザで開く。アプリ(app-dev)起動中に別ターミナルで実行。
app-open port="3000":
  @Start-Process "http://localhost:{{port}}/"

# 起動中のアプリへ推論リクエストを 1 発投げて応答を確認（別ターミナルで実行）
# 例: just infer "日本の首都は？"  /  just infer "こんにちは" gpt-5
infer prompt deployment="":
  @pwsh -NoProfile -File scripts/call-infer.ps1 -Prompt "{{prompt}}" -Deployment "{{deployment}}"

# ----------------------------------------------------------------------------
# アプリ経由のコントロールプレーン読み取り（ステップ2）。要 az login + Contributor 相当ロール。
# az CLI 直叩き（deploy-list / models）と違い、アプリの ARM プロキシ経由で取得する。
# ----------------------------------------------------------------------------

# 起動中アプリの GET /deployments（作成済みデプロイ一覧）を叩く
gw-deployments:
  @pwsh -NoProfile -File scripts/call-get.ps1 -Path "/deployments"

# 起動中アプリの GET /models（デプロイ可能なベースモデル一覧）を叩く
gw-models:
  @pwsh -NoProfile -File scripts/call-get.ps1 -Path "/models"

# ----------------------------------------------------------------------------
# アプリ経由のコントロールプレーン書き込み（ステップ3）。要 az login + Contributor ロール。
# az CLI 直叩き（deploy-model / deploy-delete）と違い、アプリの ARM プロキシ経由で作成/削除する。
# ----------------------------------------------------------------------------

# アプリ経由でデプロイ作成。引数省略時は GPT-4.1 / GlobalStandard / TPM 10。
# 例: just gw-deploy-create  /  just gw-deploy-create gpt-5 gpt-5 2025-08-07 GlobalStandard 10
gw-deploy-create name="gpt-4.1" model="gpt-4.1" version="2025-04-14" sku="GlobalStandard" capacity="10":
  @pwsh -NoProfile -File scripts/create-deployment.ps1 -DeploymentName "{{name}}" -ModelName "{{model}}" -ModelVersion "{{version}}" -Sku "{{sku}}" -Capacity {{capacity}}

# アプリ経由でデプロイ削除（後片付け）。例: just gw-deploy-delete gpt-4.1
gw-deploy-delete name:
  @pwsh -NoProfile -File scripts/delete-deployment.ps1 -DeploymentName "{{name}}"
