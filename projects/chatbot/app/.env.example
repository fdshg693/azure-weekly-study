# ============================================================================
# ローカル開発用 環境変数サンプル
# ============================================================================
# このファイルを app/.env にコピーして値を埋める（.env は .gitignore 済み）。
#   cp .env.example .env
#
# - 既存の環境変数（シェルで export 済みのもの）が優先され、.env では上書きされない。
# - App Service 上には .env を置かないため、本番では App Settings の値が使われる。
# - Entra 関連の値（TENANT_ID / CLIENT_ID / CLIENT_SECRET / EXPRESS_SESSION_SECRET）は
#   `just auth-setup` が生成する ../auth.auto.tfvars に同じ値が入っている。

# ----------------------------------------------------------------------------
# Azure OpenAI（チャット機能）
# ----------------------------------------------------------------------------
# `terraform output -raw openai_endpoint` で取得（just dev は自動 inject するので任意）
# --- Chat Completions 用（gpt-4o-mini）。experiments/tools-demo.js が使う ---
AZURE_OPENAI_ENDPOINT=https://aoai-chatbot-dev-seiwan.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Chat Completions は旧 api-version でも動く。Responses 用とはキーを分ける。
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Responses API 用（gpt-5）。server.js / experiments/responses-demo.js が使う ---
# /chat（server.js）は Responses API を使うため、推論モデル gpt-5 のデプロイ名を指定する。
# gpt-4o-mini は非推論モデルで reasoning.effort を受け付けない（400 になる）ため不可。
# 未設定なら AZURE_OPENAI_DEPLOYMENT → "gpt-5" の順にフォールバックする。
AZURE_OPENAI_RESPONSES_DEPLOYMENT=gpt-5
# Responses API は Responses 対応のプレビュー版が必須（旧 2024-10-21 は 404 になる）。
# Chat Completions 用 AZURE_OPENAI_API_VERSION とはキーを分け、モデル併用を可能にする。
AZURE_OPENAI_RESPONSES_API_VERSION=2025-04-01-preview
# gpt-5 の推論の強さ（minimal / low / medium / high）。未設定なら low。
# AZURE_OPENAI_REASONING_EFFORT=low

# ----------------------------------------------------------------------------
# Tavily リモート MCP（Web 検索ツール）
# ----------------------------------------------------------------------------
# キーの取得順: ① Key Vault（KEY_VAULT_URI があれば） → ② 下の TAVILY_API_KEY。
# ローカル開発では KEY_VAULT_URI を設定せず、この env だけ入れれば動く。
# Azure 上では KEY_VAULT_URI が App Setting で入り、キーは Key Vault から取得される
# （`just tavily-set` で投入。App Setting や Terraform state には値を残さない）。
#
# https://app.tavily.com で取得した API キー。設定すると AI に Tavily の
# Web 検索ツールが追加される（未設定なら追加されない）。ローカルで MCP は立てず、
# Tavily がホストするリモート MCP サーバーに Azure OpenAI 側から直接接続する。
TAVILY_API_KEY=tvly-your-api-key-here
# 既定は https://mcp.tavily.com/mcp/ （通常は変更不要）
# TAVILY_MCP_URL=https://mcp.tavily.com/mcp/
#
# 以下はローカルで「Key Vault からの取得」を試したい場合のみ設定する（通常は不要）。
# 設定すると上の TAVILY_API_KEY より Key Vault が優先される（`az login` の権限で読む）。
# KEY_VAULT_URI=https://kv-chatbot-dev-seiwan.vault.azure.net/
# TAVILY_SECRET_NAME=tavily-api-key

# ----------------------------------------------------------------------------
# サーバー / セッション
# ----------------------------------------------------------------------------
PORT=3000
# ローカルは development のままにすると secure cookie 要件が外れて http で動く
NODE_ENV=development
EXPRESS_SESSION_SECRET=dev-secret-please-change

# ----------------------------------------------------------------------------
# Microsoft Entra ID 認証（/profile・/profile-obo）
# ----------------------------------------------------------------------------
CLOUD_INSTANCE=https://login.microsoftonline.com/
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=11111111-1111-1111-1111-111111111111
CLIENT_SECRET=your-client-secret-here
GRAPH_API_ENDPOINT=https://graph.microsoft.com/

# ローカルのリダイレクト URI（App Registration に登録済みであること。just auth-setup が登録）
REDIRECT_URI=http://localhost:3000/auth/redirect
POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
# 未設定なら REDIRECT_URI から自動導出される（/auth/redirect → /auth/redirect-obo）
REDIRECT_URI_OBO=http://localhost:3000/auth/redirect-obo
