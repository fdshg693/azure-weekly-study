set shell := ["pwsh.exe", "-NoLogo", "-NoProfile", "-Command"]

# Terraform variables.tf のデフォルト値と合わせる
resource_group := "rg-chatbot-dev-seiwan"
web_app_name   := "webapp-chatbot-dev-seiwan"
app_dir        := "app"
func_dir       := "function"
zip_path       := "app.zip"
entra_app_name := "chatbot-graph-demo"
# メモ Function App 名（variables.tf の func_app_name デフォルトと合わせる）
func_app_name  := "func-chatbot-memo-dev-seiwan"
# Key Vault 上の Tavily シークレット名（variables.tf の tavily_secret_name と合わせる）
tavily_secret := "tavily-api-key"

default:
  @just --list

# ----------------------------------------------------------------------------
# Terraform
# ----------------------------------------------------------------------------

# Terraform プロバイダーを初期化
init:
  @terraform init

# 変更内容のプレビュー
plan:
  @terraform plan

# インフラを作成・更新（確認なし）
apply:
  @terraform apply -auto-approve

# インフラを削除（確認なし）
destroy:
  @terraform destroy -auto-approve

# 出力値を表示
output:
  @terraform output

# ----------------------------------------------------------------------------
# アプリのパッケージング・デプロイ
# ----------------------------------------------------------------------------

# app/ を zip にパッケージング（node_modules は同梱せず、App Service 側で Oryx がビルド）
package:
  @if (Test-Path {{zip_path}}) { Remove-Item {{zip_path}} -Force }; if (Test-Path "{{app_dir}}/node_modules") { Remove-Item "{{app_dir}}/node_modules" -Recurse -Force }; Compress-Archive -Path {{app_dir}}/* -DestinationPath {{zip_path}}; Write-Host "Created {{zip_path}}"

# パッケージして Web App にデプロイ（zip deploy）
deploy: package
  @az webapp deploy --resource-group {{resource_group}} --name {{web_app_name}} --src-path {{zip_path}} --type zip

# インフラ作成 → アプリデプロイをまとめて実行
up: apply deploy

# ----------------------------------------------------------------------------
# Entra ID 認証（App Registration）
# ----------------------------------------------------------------------------
# az コマンドは長くなりがちなので justfile に直書きせず、必ず scripts/ 配下の
# PowerShell スクリプトを呼び出す方針にしている。

# App Registration を作成/更新し、auth.auto.tfvars に値を書き出す（手動設定の自動化）
auth-setup:
  @pwsh -NoProfile -File scripts/setup-entra-app.ps1 -WebAppName "{{web_app_name}}" -DisplayName "{{entra_app_name}}"

# 現在の App Registration の状態・許可済スコープを確認（読み取り専用）
auth-show:
  @pwsh -NoProfile -File scripts/show-entra-app.ps1 -DisplayName "{{entra_app_name}}"

# App Registration と auth.auto.tfvars を削除（後片付け）
auth-destroy:
  @pwsh -NoProfile -File scripts/destroy-entra-app.ps1 -DisplayName "{{entra_app_name}}"

# ----------------------------------------------------------------------------
# 共有メモ Function（Azure Function / Table Storage）
# ----------------------------------------------------------------------------
# 全ユーザー共有メモの CRUD を行う Function。アプリは Web App の MI で呼ぶ（OBO ではない）。

# Function をローカル起動（事前に Azurite と Azure Functions Core Tools が必要）。
# 別ターミナルで `azurite` を起動しておくこと（Table エミュレータ）。
func-dev:
  @Push-Location {{func_dir}}; npm install; func start; Pop-Location

# Function を Azure にデプロイ（func azure functionapp publish）。
# 事前に `just apply` で Function App を作成しておくこと。
func-deploy:
  @Push-Location {{func_dir}}; npm install; func azure functionapp publish {{func_app_name}}; Pop-Location

# メモ Function を Entra で保護し、Web App の MI に app role(Memo.ReadWrite) を割り当て。
# 実行後は `just apply` で EasyAuth が有効化される（memo.auto.tfvars 反映）。
memo-api-setup:
  @pwsh -NoProfile -File scripts/setup-memo-api.ps1 -WebAppName "{{web_app_name}}" -ResourceGroup "{{resource_group}}"

# メモ API の App Registration / app role 割り当て状況を確認（読み取り専用）。
memo-api-show:
  @pwsh -NoProfile -File scripts/show-memo-api.ps1 -WebAppName "{{web_app_name}}" -ResourceGroup "{{resource_group}}"

# メモ API の App Registration を削除し memo.auto.tfvars を片付け（後片付け）。
memo-api-destroy:
  @pwsh -NoProfile -File scripts/destroy-memo-api.ps1

# ----------------------------------------------------------------------------
# テストユーザー（別ユーザーでログインすると AI の答えが変わる体験用）
# ----------------------------------------------------------------------------
# OBO チャットは get_user_profile でサインイン本人の Graph /me を返す。
# 自分とは別のテストユーザーを用意し、「誰でログインしたか」で結果が変わるのを体験する。
# （作成・削除までを just で行い、ログイン操作はブラウザで手動）

# Entra にテストユーザーを作成し、UPN と初期パスワードを表示
user-create:
  @pwsh -NoProfile -File scripts/test-user.ps1 -Action create

# テストユーザーの現在のプロフィールを表示（読み取り専用）
user-show:
  @pwsh -NoProfile -File scripts/test-user.ps1 -Action show

# テストユーザーを削除（後片付け）
user-delete:
  @pwsh -NoProfile -File scripts/test-user.ps1 -Action delete

# ----------------------------------------------------------------------------
# Tavily リモート MCP（Web 検索）の API キー — Key Vault へ投入
# ----------------------------------------------------------------------------
# キー本体は Terraform/state に入れず、ここで Key Vault に直接書き込む。
# 値は $env:TAVILY_API_KEY から読む（コマンド履歴に秘密値を残さないため）。
#   $env:TAVILY_API_KEY = "tvly-xxxx"; just tavily-set
# アプリは実行時に Web App のマネージド ID でこの値を読む（再起動不要で反映）。
tavily-set:
  @if (-not $env:TAVILY_API_KEY) { Write-Error 'まず $env:TAVILY_API_KEY = "tvly-..." を設定してください'; exit 1 }; $vault = (terraform output -raw key_vault_name); az keyvault secret set --vault-name $vault --name "{{tavily_secret}}" --value $env:TAVILY_API_KEY --output none; Write-Host "Set {{tavily_secret}} in $vault"

# Key Vault に入っている Tavily キーの「メタ情報」を確認（値は伏せて先頭だけ表示）
tavily-show:
  @$vault = (terraform output -raw key_vault_name); $v = (az keyvault secret show --vault-name $vault --name "{{tavily_secret}}" --query value -o tsv); if ($v) { Write-Host "$($v.Substring(0, [Math]::Min(8, $v.Length)))... (len=$($v.Length))" } else { Write-Host "未設定" }

# Key Vault から Tavily キーを削除（ツールが消える挙動を体験する用）
tavily-delete:
  @$vault = (terraform output -raw key_vault_name); az keyvault secret delete --vault-name $vault --name "{{tavily_secret}}" --output none; Write-Host "Deleted {{tavily_secret}} from $vault"

# ----------------------------------------------------------------------------
# ローカル開発
# ----------------------------------------------------------------------------

# ローカルで Express を起動（事前に `az login` 済みであること）
# AZURE_OPENAI_ENDPOINT は terraform output から自動取得
dev:
  @$endpoint = (terraform output -raw openai_endpoint); $env:AZURE_OPENAI_ENDPOINT = $endpoint; Push-Location {{app_dir}}; npm install; npm start; Pop-Location

# ローカル開発に必要な OpenAI ロール（Cognitive Services OpenAI User）を自分に付与（初回のみ）
grant-self: aoai-grant-self

# 自分に Azure OpenAI のデータ操作ロールを付与（tools-demo.js / dev で 401 を解消）
aoai-grant-self:
  @pwsh -NoProfile -File scripts/openai-role.ps1 -Action grant

# 自分のロール割り当て状況を確認（読み取り専用）
aoai-role-show:
  @pwsh -NoProfile -File scripts/openai-role.ps1 -Action show

# 自分から OpenAI ロールを剥奪（401 に戻る挙動を体験する用）
aoai-revoke-self:
  @pwsh -NoProfile -File scripts/openai-role.ps1 -Action revoke

# ----------------------------------------------------------------------------
# 動作確認
# ----------------------------------------------------------------------------

# Web App の URL を表示
url:
  @terraform output -raw web_app_url

# ブラウザで Web App を開く
open:
  @az webapp browse --name {{web_app_name}} --resource-group {{resource_group}}

# アプリのログをストリーミング
logs:
  @az webapp log tail --name {{web_app_name}} --resource-group {{resource_group}}

# HTTP 応答ヘッダーを確認
curl:
  @$hostname = terraform output -raw web_app_default_hostname; curl.exe -sI "https://$hostname"
