set shell := ["pwsh.exe", "-NoLogo", "-NoProfile", "-Command"]

# Terraform variables.tf のデフォルト値と合わせる
resource_group := "rg-chatbot-dev-seiwan"
web_app_name   := "webapp-chatbot-dev-seiwan"
app_dir        := "app"
zip_path       := "app.zip"
entra_app_name := "chatbot-graph-demo"

default:
  @just --list

# ----------------------------------------------------------------------------
# Terraform
# ----------------------------------------------------------------------------

# Terraform プロバイダーを初期化
init:
  @terraform init

# 変更内容のプレビュー
plan:
  @terraform plan

# インフラを作成・更新（確認なし）
apply:
  @terraform apply -auto-approve

# インフラを削除（確認なし）
destroy:
  @terraform destroy -auto-approve

# 出力値を表示
output:
  @terraform output

# ----------------------------------------------------------------------------
# アプリのパッケージング・デプロイ
# ----------------------------------------------------------------------------

# app/ を zip にパッケージング（node_modules は同梱せず、App Service 側で Oryx がビルド）
package:
  @if (Test-Path {{zip_path}}) { Remove-Item {{zip_path}} -Force }; if (Test-Path "{{app_dir}}/node_modules") { Remove-Item "{{app_dir}}/node_modules" -Recurse -Force }; Compress-Archive -Path {{app_dir}}/* -DestinationPath {{zip_path}}; Write-Host "Created {{zip_path}}"

# パッケージして Web App にデプロイ（zip deploy）
deploy: package
  @az webapp deploy --resource-group {{resource_group}} --name {{web_app_name}} --src-path {{zip_path}} --type zip

# インフラ作成 → アプリデプロイをまとめて実行
up: apply deploy

# ----------------------------------------------------------------------------
# Entra ID 認証（App Registration）
# ----------------------------------------------------------------------------
# az コマンドは長くなりがちなので justfile に直書きせず、必ず scripts/ 配下の
# PowerShell スクリプトを呼び出す方針にしている。

# App Registration を作成/更新し、auth.auto.tfvars に値を書き出す（手動設定の自動化）
auth-setup:
  @pwsh -NoProfile -File scripts/setup-entra-app.ps1 -WebAppName "{{web_app_name}}" -DisplayName "{{entra_app_name}}"

# 現在の App Registration の状態・許可済スコープを確認（読み取り専用）
auth-show:
  @pwsh -NoProfile -File scripts/show-entra-app.ps1 -DisplayName "{{entra_app_name}}"

# App Registration と auth.auto.tfvars を削除（後片付け）
auth-destroy:
  @pwsh -NoProfile -File scripts/destroy-entra-app.ps1 -DisplayName "{{entra_app_name}}"

# ----------------------------------------------------------------------------
# テストユーザー（別ユーザーでログインすると AI の答えが変わる体験用）
# ----------------------------------------------------------------------------
# OBO チャットは get_user_profile でサインイン本人の Graph /me を返す。
# 自分とは別のテストユーザーを用意し、「誰でログインしたか」で結果が変わるのを体験する。
# （作成・削除までを just で行い、ログイン操作はブラウザで手動）

# Entra にテストユーザーを作成し、UPN と初期パスワードを表示
user-create:
  @pwsh -NoProfile -File scripts/test-user.ps1 -Action create

# テストユーザーの現在のプロフィールを表示（読み取り専用）
user-show:
  @pwsh -NoProfile -File scripts/test-user.ps1 -Action show

# テストユーザーを削除（後片付け）
user-delete:
  @pwsh -NoProfile -File scripts/test-user.ps1 -Action delete

# ----------------------------------------------------------------------------
# ローカル開発
# ----------------------------------------------------------------------------

# ローカルで Express を起動（事前に `az login` 済みであること）
# AZURE_OPENAI_ENDPOINT は terraform output から自動取得
dev:
  @$endpoint = (terraform output -raw openai_endpoint); $env:AZURE_OPENAI_ENDPOINT = $endpoint; Push-Location {{app_dir}}; npm install; npm start; Pop-Location

# ローカル開発に必要な OpenAI ロール（Cognitive Services OpenAI User）を自分に付与（初回のみ）
grant-self: aoai-grant-self

# 自分に Azure OpenAI のデータ操作ロールを付与（tools-demo.js / dev で 401 を解消）
aoai-grant-self:
  @pwsh -NoProfile -File scripts/openai-role.ps1 -Action grant

# 自分のロール割り当て状況を確認（読み取り専用）
aoai-role-show:
  @pwsh -NoProfile -File scripts/openai-role.ps1 -Action show

# 自分から OpenAI ロールを剥奪（401 に戻る挙動を体験する用）
aoai-revoke-self:
  @pwsh -NoProfile -File scripts/openai-role.ps1 -Action revoke

# ----------------------------------------------------------------------------
# 動作確認
# ----------------------------------------------------------------------------

# Web App の URL を表示
url:
  @terraform output -raw web_app_url

# ブラウザで Web App を開く
open:
  @az webapp browse --name {{web_app_name}} --resource-group {{resource_group}}

# アプリのログをストリーミング
logs:
  @az webapp log tail --name {{web_app_name}} --resource-group {{resource_group}}

# HTTP 応答ヘッダーを確認
curl:
  @$hostname = terraform output -raw web_app_default_hostname; curl.exe -sI "https://$hostname"
