# message_app 共通 .env のサンプル。`task env-init`（or 手動コピー）で .env を作る。
# api/ と bff/ から読まれる。Functions は functions/local.settings.json を使う。
# ---------------------------------------------------------------------------
# ローカル既定値（docker-compose の Cosmos Emulator / Redis / Azurite 前提）。
# Azure 接続時はデプロイ後の値で上書きする（`task env-azure` が自動生成）。

# --- Cosmos DB（既定は Emulator の公開キー） ---
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DB=messageapp
COSMOS_VERIFY_TLS=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# --- キャッシュ TTL（秒）。短いほど陳腐化→回復を体験しやすい ---
CACHE_TTL_SECONDS=60

# --- BFF（下流の振り分け先） ---
PORT=3000
API_BASE_URL=http://localhost:8000
FUNCTIONS_BASE_URL=http://localhost:7071
# Azure 上で Functions を function キー保護する場合のみ設定（ローカルは空）
FUNCTIONS_KEY=
