      "description": "No request body is required.",
      "headers": [],
      "queryParameters": [],
      "representations": []
    },
    "responses": [
      {
        "statusCode": 200,
        "description": "Returns the requested item.",
        "representations": [
          {
            "contentType": "application/json",
            "examples": {
              "sample": {
                "summary": "Get item response",
