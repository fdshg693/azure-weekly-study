// ============================================================================
// ローカル専用の上書きパラメータ例
// ============================================================================
// このファイルを main.local.bicepparam にコピーして利用してください。
// main.local.bicepparam は .gitignore で除外されます。
// 機密値や個人用設定、実運用向けの連絡先はこのローカルファイルへ分離します。

using './main.bicep'

param prefix = 'apimlearnlocal'

// APIM を削除してすぐ再作成すると soft-delete で同名がブロックされることがあります
// その場合は just apim-purge で古い APIM を purge するか、suffix を変えて別名で作成してください
// param suffix = 'local001'

param apimPublisherName = 'Your Team Name'
param apimPublisherEmail = 'your-team@example.com'

// Azure OpenAI リソースとモデルデプロイをこのテンプレートで作成したい場合だけ有効化してください
// APIM へ渡す AOAI の URL は、azure-openai.bicep の output を main.bicep 経由で利用します
// param enableAzureOpenAiApi = true
// param azureOpenAiLocation = 'japaneast'
// param azureOpenAiDeploymentName = 'gpt-4o-mini'
// param azureOpenAiModelName = 'gpt-4o-mini'
// param azureOpenAiModelVersion = ''
// gpt-4o-mini を japaneast に作る場合は GlobalStandard を使ってください
// param azureOpenAiDeploymentSkuName = 'GlobalStandard'
// param azureOpenAiDeploymentCapacity = 10

// BACKEND_SHARED_SECRET の渡し方（学習ポイント）
//
// 1) デフォルトでは main.bicep で newGuid() が呼ばれて自動生成される（再デプロイで値が変わる点に注意）。
//    シークレットは Key Vault に格納され、Function App / APIM 双方から Managed Identity で参照される。
//
// 2) 固定値を渡す場合は以下のように直接代入する。
//    param backendSharedSecret = '<set-only-in-local-file>'
//
// 3) 推奨: 既存の Key Vault からデプロイ時に取り出す（値が bicepparam にも tfstate にも残らない）。
//    使う前に対象の Key Vault に "bootstrap-backend-secret" などのシークレットを手動で 1 回投入しておく。
//
//    param backendSharedSecret = az.getSecret(
//      subscription().subscriptionId,
//      'rg-bootstrap',
//      'kv-bootstrap-xxx',
//      'bootstrap-backend-secret'
//    )

param tags = {
  Environment: 'Local'
  Project: 'BicepFunctionsCRUD'
  ManagedBy: 'Bicep'
}
